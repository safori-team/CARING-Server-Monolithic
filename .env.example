
# ==================================================
# CARING Server 환경변수
# 복사: cp .env.example .env
# ==================================================

# --- 서버 ---
SERVER_PORT=8080
MANAGEMENT_SERVER_PORT=9082

# --- JWT (필수) ---
TOKEN_SECRET_USER=<your-base64-encoded-jwt-secret-256bit-minimum>

# --- DB (필수) ---
# 로컬 Docker MySQL 사용 시 (compose.yaml에 포함)
DB_URL=jdbc:mysql://localhost:3306/caring?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=Asia/Seoul
DB_USERNAME=caring
DB_PASSWORD=caring
# AWS RDS 사용 시 아래로 교체
# DB_URL=jdbc:mysql://<rds-endpoint>:3306/caring?useSSL=true&serverTimezone=Asia/Seoul
# DB_USERNAME=<rds-user>
# DB_PASSWORD=<rds-password>

# --- JPA ---
JPA_DDL_AUTO=update
JPA_SHOW_SQL=false

# --- Redis (필수) ---
# 로컬 Docker Redis 사용 시 (compose.yaml에 포함)
REDIS_HOST=localhost
REDIS_PORT=6379
# 외부 Redis 사용 시 아래로 교체
# REDIS_HOST=<redis-host>

# --- AWS / SQS ---
AWS_ACCESS_KEY=<your-aws-access-key>
AWS_SECRET_KEY=<your-aws-secret-key>
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=<your-s3-bucket-name>
DIARY_TO_CHATBOT_SQS_URL=<your-sqs-queue-url>

# --- FCM 푸시 알림 (선택) ---
# Firebase 서비스 계정 JSON을 Base64 인코딩한 값
# 비워두면 푸시 알림 비활성화
FCM_KEY_BASE64=

# --- Hume AI 음성 감정 분석 (선택) ---
HUME_API_KEY=<your-hume-api-key>
# HUME_BASE_URL=https://api.hume.ai/v0
HUME_CALLBACK_URL=http://localhost:8080/v1/api/hume/callback
# EC2 배포 시: http://52.79.73.129:8080/v1/api/hume/callback

# --- OpenAI 주간/월간 리포트 (선택) ---
OPENAI_API_KEY=<your-openai-api-key>
OPENAI_MODEL=gpt-4o-mini
