# Normalize line endings to LF on commit
* text=auto eol=lf

# Explicitly LF for config/source files
*.java text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.xml  text eol=lf
*.properties text eol=lf
*.sql  text eol=lf
*.sh   text eol=lf

# Binary files — no conversion
*.jar  binary
*.png  binary
*.jpg  binary
*.gif  binary
